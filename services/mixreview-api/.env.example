PORT=4301
NODE_ENV=development

# Comma-separated browser origins allowed to call the API.
# Production should include https://mixreview.kingzbreadent.com.
CORS_ORIGINS=http://localhost:4300,http://localhost:4302,https://mixreview.kingzbreadent.com
CLIENT_ORIGIN=https://mixreview.kingzbreadent.com

# Cloudflare R2 storage.
CLOUDFLARE_ACCOUNT_ID=PASTE_ACCOUNT_ID
CLOUDFLARE_R2_BUCKET=mixreview-audio
R2_PUBLIC_BASE_URL=

# R2 uploads use only S3-compatible credentials.
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
